# ==================== GOOGLE GEMINI API ====================
# Get your free API key from: https://makersuite.google.com/
GEMINI_API_KEY=your_api_key_here

# ==================== APPLICATION SETTINGS ====================
# Theme: light, dark, auto
APP_THEME=light

# Host and port for Streamlit
STREAMLIT_HOST=localhost
STREAMLIT_PORT=8501

# ==================== ADVANCED SETTINGS ====================
# Enable/disable specific features
ENABLE_CHATBOT=true
ENABLE_INSIGHTS=true
ENABLE_VISUALIZATIONS=true

# Maximum file upload size in MB
MAX_UPLOAD_SIZE=500

# Debug mode (verbose logging)
DEBUG_MODE=false

# ==================== NOTES ====================
# 1. Copy this file to .env and fill in your actual values
# 2. Do NOT commit .env to version control
# 3. Keep API keys secret and never share them
# 4. Restart the application after changing .env variables
